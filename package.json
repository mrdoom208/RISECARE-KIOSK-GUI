{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "esbuild",
      "msw",
      "unrs-resolver"
    ]
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @workspace/api-server --filter @workspace/risecare-kiosk run dev",
    "test:api": "echo 'No API tests configured'",
    "dev:local": "pnpm --parallel --filter @workspace/api-server --filter @workspace/risecare-kiosk run dev",
    "dev:api": "pnpm --filter @workspace/api-server run dev",
    "db:push": "pnpm --filter @workspace/db run push",
    "db:migrate": "pnpm --filter @workspace/db run migrate",
    "db:studio": "pnpm --filter @workspace/db run studio",
    "build:kiosk": "pnpm --filter @workspace/risecare-kiosk run build",
    "start": "pnpm run build:kiosk && pnpm --filter @workspace/api-server run start",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "cross-env": "^10.1.0",
    "lightningcss-linux-arm64-gnu": "^1.32.0",
    "mqtt": "^5.10.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  }
}
