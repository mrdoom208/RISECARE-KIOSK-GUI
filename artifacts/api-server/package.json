{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development PORT=5000 tsx ./src/index.ts",
    "start": "cross-env NODE_ENV=production PORT=5000 tsx ./src/index.ts",
    "build": "tsx ./build.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
   "dependencies": {
     "@workspace/api-zod": "workspace:*",
     "@workspace/db": "workspace:*",
     "body-parser": "^2.2.2",
     "cookie-parser": "^1.4.7",
     "cors": "^2",
     "dotenv": "^17.3.1",
     "express": "^5",
     "mqtt": "^5.15.1"
   },
   "devDependencies": {
     "@types/cookie-parser": "^1.4.10",
     "@types/cors": "^2.8.19",
     "@types/express": "^5.0.6",
     "@types/node": "^24.0.0",
     "esbuild": "^0.27.3",
     "tsx": "^4.21.0"
   }
}